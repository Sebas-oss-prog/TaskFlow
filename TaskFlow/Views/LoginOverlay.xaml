<UserControl x:Class="TaskFlow.Views.LoginOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:material="http://materialdesigninxaml.net/winfx/xaml/themes"
             Focusable="True"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <Grid Background="#80000000">
        <Border Background="Transparent"/>

        <material:Card Width="460"
                       Padding="40"
                       UniformCornerRadius="24"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
            <StackPanel Width="360" HorizontalAlignment="Center">
                <Border Width="76"
                        Height="76"
                        Margin="0,0,0,20"
                        HorizontalAlignment="Center"
                        Background="#FFF2F5FB"
                        CornerRadius="22">
                    <material:PackIcon Kind="ClipboardTextClockOutline"
                                       Width="34"
                                       Height="34"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#FF3559E0"/>
                </Border>

                <TextBlock Text="РайПО Задачи"
                           FontSize="30"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="#FF3559E0"/>

                <TextBlock Text="Слободское РайПО"
                           Margin="0,8,0,0"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Foreground="#FF6B7280"/>

                <TextBlock Text="Вход в систему"
                           Margin="0,28,0,24"
                           FontSize="22"
                           FontWeight="Medium"
                           HorizontalAlignment="Center"/>

                <TextBox x:Name="txtLogin"
                         Height="52"
                         FontSize="15"
                         material:HintAssist.Hint="Логин"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                <PasswordBox x:Name="txtPassword"
                             Margin="0,16,0,0"
                             Height="52"
                             Padding="16,0"
                             FontSize="15"
                             material:HintAssist.Hint="Пароль"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"/>

                <Button Content="Войти"
                        Height="50"
                        Margin="0,24,0,0"
                        FontSize="16"
                        FontWeight="Medium"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="BtnLogin_Click"/>
            </StackPanel>
        </material:Card>
    </Grid>
</UserControl>
