<UserControl x:Class="TaskFlow.Views.CalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:material="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid Background="#F8F9FA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Календарь -->
        <material:Card Margin="20" Padding="20" UniformCornerRadius="12">
            <Calendar x:Name="MainCalendar"
                      SelectedDatesChanged="MainCalendar_SelectedDatesChanged"
                      Margin="10"
                      Height="380"/>
        </material:Card>

        <!-- Задачи на выбранный день -->
        <material:Card Grid.Column="1" Margin="20" Padding="20" UniformCornerRadius="12">
            <StackPanel>
                <TextBlock x:Name="txtSelectedDate" 
                           Text="Выберите дату в календаре" 
                           FontSize="22" 
                           FontWeight="SemiBold"
                           Foreground="#3F51B5"
                           Margin="0,0,0,20"/>

                <ListView x:Name="lvDayTasks" Margin="0,10">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <material:Card Margin="0,6" Padding="14" UniformCornerRadius="10">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" 
                                               FontSize="15.5" 
                                               FontWeight="Medium"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding ResponsibleName}" 
                                               Margin="0,6,0,0"
                                               FontSize="13.5"
                                               Foreground="#3F51B5"/>
                                    <TextBlock Text="{Binding Status}" 
                                               Margin="0,8,0,0"
                                               FontWeight="Medium"
                                               Foreground="#FF9800"/>
                                </StackPanel>
                            </material:Card>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock x:Name="txtNoTasks" 
                           Text="На выбранный день задач нет"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="16"
                           Foreground="#9E9E9E"
                           Margin="0,100,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </material:Card>
    </Grid>
</UserControl>