<UserControl x:Class="TaskFlow.Views.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:material="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid Background="{DynamicResource MaterialDesign.Brush.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="24,20,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Управление пользователями" FontSize="28" FontWeight="SemiBold"/>
                <TextBlock Text="Только для администратора: добавление, редактирование и блокировка доступа." Margin="0,8,0,0" Opacity="0.72" FontSize="14"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Добавить пользователя"
                    Height="44"
                    Padding="24,0"
                    Command="{Binding AddUserCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"/>
        </Grid>

        <ListView Grid.Row="1"
                  Margin="24,0,24,24"
                  ItemsSource="{Binding Users}"
                  BorderThickness="0"
                  Background="Transparent">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <material:Card Margin="0,0,0,12" Padding="18" UniformCornerRadius="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <WrapPanel>
                                    <TextBlock Text="{Binding FullName}" FontSize="17" FontWeight="SemiBold"/>
                                    <Border Margin="12,0,0,0" Padding="10,3" CornerRadius="12" Background="#FFF1F5F9">
                                        <TextBlock Text="{Binding RoleDisplay}" FontSize="12" FontWeight="Medium"/>
                                    </Border>
                                    <Border Margin="8,0,0,0" Padding="10,3" CornerRadius="12" Background="#FFFFF4E5">
                                        <TextBlock Text="{Binding StatusDisplay}" FontSize="12" FontWeight="Medium"/>
                                    </Border>
                                </WrapPanel>

                                <TextBlock Text="{Binding Login, StringFormat=Логин: {0}}" Margin="0,10,0,0" Opacity="0.78"/>
                                <TextBlock Text="{Binding Email, StringFormat=Эл. почта: {0}}" Margin="0,4,0,0" Opacity="0.78"/>
                                <TextBlock Text="{Binding Phone, StringFormat=Телефон: {0}}" Margin="0,4,0,0" Opacity="0.78"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                <Button Content="Редактировать"
                                        Margin="0,0,10,0"
                                        Padding="18,0"
                                        Command="{Binding DataContext.EditUserCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"/>

                                <Button Padding="18,0"
                                        Command="{Binding DataContext.ToggleUserBlockedCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Администратора и председателя блокировать нельзя."
                                        Style="{StaticResource MaterialDesignRaisedButton}">
                                    <Button.Content>
                                        <TextBlock Text="Разблокировать">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Заблокировать"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                                            <Setter Property="Text" Value="Разблокировать"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Button.Content>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </material:Card>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>

