<Window x:Class="TaskFlow.Views.UserEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:material="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Пользователь"
        Height="620"
        Width="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesign.Brush.Background}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="#FFF7F9FC" Padding="28,24" CornerRadius="0,0,24,24">
            <StackPanel>
                <TextBlock Text="{Binding WindowTitle}" FontSize="28" FontWeight="SemiBold"/>
                <TextBlock Text="Измените основные данные сотрудника, его роль и доступ в систему." Margin="0,8,0,0" Opacity="0.72" FontSize="14"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="28,24,28,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBox Grid.Row="0"
                     Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                     material:HintAssist.Hint="ФИО *"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

            <ComboBox Grid.Row="2"
                      ItemsSource="{Binding RoleOptions}"
                      SelectedItem="{Binding Role}"
                      material:HintAssist.Hint="Роль *"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>

            <TextBox Grid.Row="4"
                     Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                     material:HintAssist.Hint="Логин *"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

            <TextBox Grid.Row="6"
                     Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                     material:HintAssist.Hint="Пароль *"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

            <Grid Grid.Row="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         material:HintAssist.Hint="Email"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                <TextBox Grid.Column="2"
                         Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                         material:HintAssist.Hint="Телефон"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
            </Grid>

            <CheckBox Grid.Row="10"
                      IsChecked="{Binding IsBlocked}"
                      Content="Заблокировать вход пользователю"
                      VerticalAlignment="Center"/>

            <ProgressBar Grid.Row="11"
                         Height="6"
                         Margin="0,18,0,0"
                         IsIndeterminate="True"
                         Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="28,8,28,24">
            <Button Content="Отмена"
                    Width="120"
                    Height="42"
                    Margin="0,0,10,0"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"/>

            <Button Content="Сохранить"
                    Width="150"
                    Height="42"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"/>
        </StackPanel>
    </Grid>
</Window>

