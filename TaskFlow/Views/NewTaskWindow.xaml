<Window x:Class="TaskFlow.Views.NewTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:material="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Новая задача"
        Height="620"
        Width="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesign.Brush.Background}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="#FFF7F9FC" Padding="28,24" CornerRadius="0,0,24,24">
            <StackPanel>
                <TextBlock Text="Создание задачи" FontSize="28" FontWeight="SemiBold"/>
                <TextBlock Text="Откройте форму, проверьте данные и сохраните задачу в один шаг." Margin="0,8,0,0" Opacity="0.72" FontSize="14"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="28,24,28,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBox Grid.Row="0"
                         Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                         material:HintAssist.Hint="Название задачи *"
                         FontSize="15"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                <TextBox Grid.Row="2"
                         Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                         material:HintAssist.Hint="Описание"
                         FontSize="14"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Height="150"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                <ComboBox Grid.Row="4"
                          ItemsSource="{Binding ResponsibleUsers}"
                          SelectedItem="{Binding SelectedResponsible}"
                          DisplayMemberPath="FullName"
                          material:HintAssist.Hint="Ответственный *"
                          FontSize="15"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"/>

                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <DatePicker SelectedDate="{Binding DueDate}"
                                material:HintAssist.Hint="Срок выполнения"
                                Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>

                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding Priorities}"
                              SelectedItem="{Binding SelectedPriority}"
                              material:HintAssist.Hint="Приоритет"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                </Grid>

                <Border Grid.Row="8"
                        Padding="14"
                        Background="#FFF4F7FB"
                        BorderBrush="#FFD8E2F0"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel Orientation="Horizontal">
                        <material:PackIcon Kind="LightbulbOnOutline" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Top"/>
                        <TextBlock Text="Форму можно открывать из вкладки шаблонов и прямо из ответа ИИ. Поля уже будут заполнены, а перед сохранением их можно изменить."
                                   TextWrapping="Wrap"
                                   Opacity="0.8"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <DockPanel Grid.Row="2" Margin="28,8,28,24" LastChildFill="False">
            <ProgressBar Width="140"
                         Height="6"
                         Margin="0,0,18,0"
                         VerticalAlignment="Center"
                         IsIndeterminate="True"
                         Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="Отмена"
                        Width="120"
                        Height="42"
                        Margin="0,0,10,0"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"/>

                <Button Content="Сохранить задачу"
                        Width="170"
                        Height="42"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>

