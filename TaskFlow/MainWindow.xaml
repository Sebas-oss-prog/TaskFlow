<Window x:Class="TaskFlow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:material="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="TaskFlow"
        Height="820"
        Width="1420"
        MinHeight="760"
        MinWidth="1260"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesign.Brush.Background}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid x:Name="MainGrid" Background="#FFF5F7FB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Margin="18,18,18,10" Padding="24,20" Background="#FFFDFEFF" CornerRadius="28" BorderBrush="#FFE2E8F0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="TaskFlow" FontSize="34" FontWeight="SemiBold"/>
                    <TextBlock Text="Рабочее пространство для задач, календаря, шаблонов и AI-помощника" Margin="0,8,0,0" FontSize="14" Opacity="0.72"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Padding="16,12" CornerRadius="20" Background="#FFF6F9FC" Margin="0,0,18,0">
                        <StackPanel Orientation="Horizontal">
                            <material:PackIcon Kind="AccountCircleOutline" Width="28" Height="28" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="{Binding CurrentUserFullName}" FontWeight="SemiBold" FontSize="15"/>
                                <TextBlock Text="{Binding CurrentUserRole}" Opacity="0.7" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Button Content="Сменить пользователя" Height="42" Margin="0,0,10,0" Click="BtnSwitchUser_Click" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                    <Button Content="Пользователи" Height="42" Margin="0,0,10,0" Click="BtnUsers_Click" Style="{StaticResource MaterialDesignOutlinedButton}" Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button Content="О программе" Height="42" Click="BtnAbout_Click" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18,0,18,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="#FF111827" CornerRadius="30" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Height="52" Margin="0,0,0,10" Content="Мои задачи" Click="BtnMyTasks_Click" Style="{StaticResource MaterialDesignRaisedButton}"/>
                    <Button Grid.Row="1" Height="52" Margin="0,0,0,10" Content="Календарь" Click="BtnCalendar_Click" Style="{StaticResource MaterialDesignRaisedButton}"/>
                    <Button Grid.Row="2" Height="52" Margin="0,0,0,10" Content="AI Помощник" Click="BtnAIAssistant_Click" Style="{StaticResource MaterialDesignRaisedButton}"/>
                    <Button Grid.Row="3" Height="52" Margin="0,0,0,16" Content="Шаблоны задач" Click="BtnTemplates_Click" Style="{StaticResource MaterialDesignRaisedButton}"/>

                    <Border Grid.Row="4" Padding="16" CornerRadius="22" Background="#FF1F2937">
                        <StackPanel>
                            <TextBlock Text="Состояние" Foreground="White" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding BusyMessage}" Margin="0,10,0,0" Foreground="#FFD1D5DB" TextWrapping="Wrap"/>
                            <ProgressBar Margin="0,14,0,0" Height="6" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="#FFFDFEFF" CornerRadius="30" BorderBrush="#FFE2E8F0" BorderThickness="1">
                <ContentControl x:Name="MainContentArea"/>
            </Border>
        </Grid>

        <Grid Background="#660B1220" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Width="280" Height="150" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#FFFDFEFF" CornerRadius="24" Padding="24">
                <StackPanel VerticalAlignment="Center">
                    <ProgressBar Height="6" IsIndeterminate="True"/>
                    <TextBlock Text="{Binding BusyMessage}" Margin="0,20,0,0" HorizontalAlignment="Center" FontSize="15" FontWeight="Medium" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>

